{
  "name": "akorith",
  "productName": "Akorith",
  "version": "0.9.1",
  "description": "Akorith — orchestrate AI coding agents (Claude/Codex CLIs, local Ollama) with no API keys",
  "author": "Akorith",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "predev": "node scripts/fix-dev-app-name.js && node scripts/gen-build-info.js",
    "dev": "electron-vite dev",
    "prebuild": "node scripts/gen-build-info.js",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -o better-sqlite3",
    "postinstall": "electron-rebuild -f -o better-sqlite3 && node scripts/fix-spawn-helper.js && node scripts/fix-dev-app-name.js",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "verify:workspace-loop": "tsx scripts/verify-workspace-loop.ts",
    "verify:local-executor": "node --experimental-strip-types scripts/verify-local-executor.ts",
    "verify:controller": "tsx scripts/verify-controller.ts",
    "verify:startup-hydration": "tsx scripts/verify-startup-hydration.ts",
    "verify:research-contracts": "tsx scripts/research-verify-contracts.ts",
    "verify:research-artifacts": "tsx scripts/research-verify-artifacts.ts",
    "verify:research-persistence": "electron scripts/research-persistence-main.cjs",
    "verify:research-network": "tsx scripts/research-verify-network.ts",
    "verify:research-inputs": "tsx scripts/research-verify-inputs.ts",
    "verify:research": "npm run verify:research-contracts && npm run verify:research-inputs && npm run verify:research-network && npm run verify:research-artifacts && npm run verify:research-persistence",
    "verify:research-live": "electron scripts/research-live-smoke-main.cjs",
    "verify:research-live:check": "electron scripts/research-live-smoke-main.cjs --check",
    "verify:research-seed": "electron scripts/research-seed-main.cjs",
    "verify:research-seed:help": "electron scripts/research-seed-main.cjs --help",
    "verify:update-version": "tsx scripts/verify-update-version.ts",
    "setup": "bash scripts/setup-akorith.sh",
    "setup:mac": "bash scripts/setup-akorith.sh",
    "doctor": "bash scripts/setup-akorith.sh --check",
    "release:check": "node scripts/release-check.js",
    "macos:refresh": "bash scripts/refresh-macos-app.sh",
    "refresh:mac": "bash scripts/refresh-macos-app.sh",
    "refresh:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/refresh-windows-app.ps1",
    "clean:apps": "bash scripts/clean-old-akorith-apps.sh",
    "pack": "npm run build && electron-builder --dir",
    "pack:mac": "npm run build && electron-builder --mac --dir",
    "pack:win": "npm run build && electron-builder --win --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder -mw",
    "verify:local-runtime": "tsx scripts/verify-local-runtime.ts",
    "verify:project-loop": "tsx scripts/verify-project-loop.ts",
    "verify:goal-cycle": "tsx scripts/verify-goal-cycle.ts",
    "verify:companions": "tsx scripts/verify-companions.ts",
    "verify:agents": "tsx scripts/verify-agents.ts",
    "verify:opencode-output": "tsx scripts/verify-opencode-output.ts",
    "verify:plugin-tools": "tsx scripts/verify-plugin-tools.ts",
    "verify:windows-identity": "tsx scripts/verify-windows-app-identity.ts"
  },
  "build": {
    "appId": "com.akorith.app",
    "productName": "Akorith",
    "copyright": "Copyright © 2026 Akorith",
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "build/icon.ico",
      "build-info.json",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "node_modules/dejavu-fonts-ttf/ttf/DejaVuSans.ttf",
        "to": "research-fonts/DejaVuSans.ttf"
      },
      {
        "from": "node_modules/dejavu-fonts-ttf/ttf/DejaVuSans-Bold.ttf",
        "to": "research-fonts/DejaVuSans-Bold.ttf"
      },
      {
        "from": "node_modules/dejavu-fonts-ttf/LICENSE",
        "to": "research-fonts/LICENSE"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "executableName": "Akorith",
      "signAndEditExecutable": true,
      "artifactName": "${productName}-${version}-win-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "menuCategory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "shortcutName": "Akorith",
      "uninstallDisplayName": "Akorith ${version}",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "node-pty": "^1.1.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "dejavu-fonts-ttf": "^2.37.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
