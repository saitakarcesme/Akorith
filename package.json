{
  "name": "akorith",
  "productName": "Akorith",
  "version": "0.1.0",
  "description": "Akorith — orchestrate AI coding agents (Claude/Codex CLIs, local Ollama) with no API keys",
  "author": "Akorith",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "predev": "node scripts/fix-dev-app-name.js && node scripts/gen-build-info.js",
    "dev": "electron-vite dev",
    "prebuild": "node scripts/gen-build-info.js",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -o better-sqlite3",
    "postinstall": "electron-rebuild -f -o better-sqlite3 && node scripts/fix-spawn-helper.js && node scripts/fix-dev-app-name.js",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && npm run typecheck:test",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --workspace vitest.workspace.mts",
    "test:watch": "vitest --workspace vitest.workspace.mts",
    "test:unit": "vitest run --workspace vitest.workspace.mts --project unit",
    "test:component": "vitest run --workspace vitest.workspace.mts --project component",
    "test:integration": "vitest run --workspace vitest.workspace.mts --project integration && npm run test:native",
    "test:native": "node scripts/run-electron-native-smoke.mjs",
    "test:coverage": "vitest run --workspace vitest.workspace.mts --coverage",
    "verify:workspace-loop": "tsx scripts/verify-workspace-loop.ts",
    "verify:local-executor": "tsx scripts/verify-local-executor.ts",
    "verify:controller": "tsx scripts/verify-controller.ts",
    "verify:startup-hydration": "tsx scripts/verify-startup-hydration.ts",
    "verify:agentic-loop": "tsx scripts/verify-agentic-loop.ts",
    "verify:bridge-autoenter": "tsx scripts/verify-bridge-autoenter.ts",
    "verify:conversation-context": "tsx scripts/verify-conversation-context.ts",
    "verify:critic-loop": "tsx scripts/verify-critic-loop.ts",
    "verify:external-url": "tsx scripts/verify-external-url.ts",
    "verify:macro-loop": "tsx scripts/verify-macro-loop.ts",
    "verify:testlab": "tsx scripts/verify-testlab.ts",
    "verify:telemetry": "node scripts/run-electron-typescript.mjs scripts/verify-telemetry.ts",
    "verify:autonomous-loop": "node scripts/run-electron-typescript.mjs scripts/verify-autonomous-loop.ts",
    "verify:model-catalog": "tsx scripts/verify-model-catalog.ts",
    "verify:model-catalog-store": "node scripts/run-electron-typescript.mjs scripts/verify-model-catalog-store.ts",
    "verify:repository": "tsx scripts/verify-repository-service.ts",
    "verify:existing": "npm run verify:agentic-loop && npm run verify:bridge-autoenter && npm run verify:conversation-context && npm run verify:critic-loop && npm run verify:external-url && npm run verify:macro-loop && npm run verify:startup-hydration && npm run verify:local-runtime && npm run verify:local-executor && npm run verify:workspace-loop && npm run verify:project-loop && npm run verify:controller && npm run verify:testlab && npm run verify:telemetry && npm run verify:autonomous-loop && npm run verify:model-catalog && npm run verify:model-catalog-store && npm run verify:repository && npm run verify:plugins && npm run verify:windows-identity",
    "verify": "npm run typecheck && npm test && npm run test:native && npm run verify:existing",
    "setup": "bash scripts/setup-akorith.sh",
    "setup:mac": "bash scripts/setup-akorith.sh",
    "doctor": "bash scripts/setup-akorith.sh --check",
    "release:check": "node scripts/release-check.js",
    "macos:refresh": "bash scripts/refresh-macos-app.sh",
    "refresh:mac": "bash scripts/refresh-macos-app.sh",
    "refresh:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/refresh-windows-app.ps1",
    "clean:apps": "bash scripts/clean-old-akorith-apps.sh",
    "pack": "npm run build && electron-builder --dir",
    "pack:mac": "npm run build && electron-builder --mac --dir",
    "pack:win": "npm run build && electron-builder --win --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder -mw",
    "verify:local-runtime": "tsx scripts/verify-local-runtime.ts",
    "verify:project-loop": "tsx scripts/verify-project-loop.ts",
    "verify:plugins": "tsx scripts/verify-plugin-marketplace.ts",
    "verify:windows-identity": "tsx scripts/verify-windows-app-identity.ts",
    "ledger": "node scripts/generate-implementation-ledger.mjs"
  },
  "build": {
    "appId": "com.akorith.app",
    "productName": "Akorith",
    "copyright": "Copyright © 2026 Akorith",
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "build/icon.ico",
      "build-info.json",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "executableName": "Akorith",
      "signAndEditExecutable": true,
      "artifactName": "${productName}-${version}-win-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "menuCategory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "shortcutName": "Akorith",
      "uninstallDisplayName": "Akorith ${version}",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.10.0",
    "node-pty": "^1.1.0",
    "pdfkit": "^0.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.1",
    "playwright-core": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
