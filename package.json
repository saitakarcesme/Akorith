{
  "name": "akorith",
  "productName": "Akorith",
  "version": "0.1.0",
  "description": "Akorith — orchestrate AI coding agents (Claude/Codex CLIs, local Ollama) with no API keys",
  "author": "Akorith",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "predev": "node scripts/fix-dev-app-name.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -o better-sqlite3",
    "postinstall": "electron-rebuild -f -o better-sqlite3 && node scripts/fix-spawn-helper.js && node scripts/fix-dev-app-name.js",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "verify:workspace-loop": "tsx scripts/verify-workspace-loop.ts",
    "verify:local-executor": "node --experimental-strip-types scripts/verify-local-executor.ts",
    "verify:controller": "tsx scripts/verify-controller.ts",
    "setup": "bash scripts/setup-akorith.sh",
    "setup:mac": "bash scripts/setup-akorith.sh",
    "doctor": "bash scripts/setup-akorith.sh --check",
    "release:check": "node scripts/release-check.js",
    "macos:refresh": "bash scripts/refresh-macos-app.sh",
    "refresh:mac": "bash scripts/refresh-macos-app.sh",
    "clean:apps": "bash scripts/clean-old-akorith-apps.sh",
    "pack": "npm run build && electron-builder --dir",
    "pack:mac": "npm run build && electron-builder --mac --dir",
    "pack:win": "npm run build && electron-builder --win --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder -mw"
  },
  "build": {
    "appId": "com.akorith.app",
    "productName": "Akorith",
    "copyright": "Copyright © 2026 Akorith",
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "assets/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Akorith"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Akorith"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.10.0",
    "node-pty": "^1.1.0",
    "pdfkit": "^0.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
